# Copy this file to .env.local and fill in your credentials.
# Never commit .env.local or real credentials to git.

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: AI-powered DM thread summaries (server-side only)
AI_API_KEY=your_ai_provider_key
AI_MODEL=your_model_name
AI_BASE_URL=optional_provider_base_url

# Optional: school name for LinkedIn Google searches (e.g. Northeastern University)
NEXT_PUBLIC_LINKEDIN_SCHOOL_CONTEXT=
